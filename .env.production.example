# ===== Гипс Стиль 31 — переменные окружения для ПРОДА (Vercel) =====
# Задаются в Vercel → Project → Settings → Environment Variables.
# НЕ коммитить реальные значения.

# БД: Neon / Vercel Postgres (Postgres 16). Подключить через Vercel Storage или вставить строку Neon.
# Для Prisma рекомендуется НЕ-pooled (direct) URL при миграциях; для рантайма можно pooled.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Шифрование персональных данных заявок (AES-256). СГЕНЕРИРУЙТЕ СВОЁ значение (в репозиторий не коммитить!):
#   openssl rand -base64 48
ENCRYPTION_KEY="CHANGE_ME_run_openssl_rand_base64_48"

# Подпись JWT для входа в админку. СГЕНЕРИРУЙТЕ СВОЁ:
JWT_SECRET="CHANGE_ME_run_openssl_rand_base64_48"

# Публичный адрес сайта (для canonical, sitemap, OpenGraph).
NEXT_PUBLIC_SITE_URL="https://ваш-домен.ru"

# Загрузка фото — Vercel Blob. Появляется автоматически при подключении Blob-хранилища в проекте.
BLOB_READ_WRITE_TOKEN=""

# Telegram-уведомления о заявках (опционально; можно задать и в админке → Настройки).
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
